@model IEnumerable<WikiJuegos_PNT1.Models.Juego>
@using System.Security.Claims;

@{
    ViewData["Title"] = "Juegos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Juegos</h2>
    <form class="d-flex" style="width: 40%" asp-action="Buscar" asp-controller="Juego" method="get">
        <input name="buscar" type="text" class="form-control form-control-sm me-2" style="width: 70%" placeholder="Buscar por nombre..." />
        <input type="submit" name="name" class="btn btn-sm btn-primary" style="width: 30%" value="Buscar" />
    </form>
</div>

<p>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a class="btn btn-outline-primary" asp-action="Create">Crear nuevo juego</a>
    }
</p>


@if (Model != null && Model.Any())
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm" style="border-radius: 15px; overflow: hidden; transition: transform .2s;">
                    <a asp-action="Details" asp-route-id="@item.Id" style="text-decoration: none; color: inherit;">
                        
                        @*  SECCIÓN DE LA IMAGEN *@
                        @if (!string.IsNullOrEmpty(item.ImagenUrl))
                        {
                            <img src="@item.ImagenUrl" class="card-img-top" alt="Portada de @item.Nombre" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-dark text-white d-flex align-items-center justify-content-center" style="height: 200px;">
                                <span class="text-uppercase fw-bold">@item.Nombre</span>
                            </div>
                        }

                        <div class="card-body">
                            <h5 class="card-title text-primary fw-bold mb-1">@item.Nombre</h5>
                            
                            @* ⭐ SISTEMA DE VALORACIÓN VISUAL *@
                            <div class="mb-2">
                                @for (int i = 0; i < item.Rating; i++)
                                {
                                    <span class="text-warning">★</span>
                                }
                                @for (int i = item.Rating; i < 5; i++)
                                {
                                    <span class="text-muted">☆</span>
                                }
                            </div>

                            <hr />
                            <p class="card-text mb-1"><strong>Estudio:</strong> @item.Desarrollador</p>
                            <p class="card-text"><span class="badge bg-info text-dark">@item.Genero</span></p>
                        </div>

                        <div class="card-footer bg-transparent border-top-0 pb-3">
                            <div class="d-grid">
                                <span class="btn btn-sm btn-outline-primary">Ver detalles del juego</span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">Todavía no hay juegos en la wiki. ¡Sé el primero en crear uno!</div>
}