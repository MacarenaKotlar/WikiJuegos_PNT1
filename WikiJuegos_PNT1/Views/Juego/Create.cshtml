@model WikiJuegos_PNT1.Models.Juego

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Juego</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
<div class="form-group mb-3">
                    <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
<div class="form-group mb-3">
                    <label asp-for="Desarrollador" class="control-label"></label>
                <input asp-for="Desarrollador" class="form-control" />
                <span asp-validation-for="Desarrollador" class="text-danger"></span>
            </div>
<div class="form-group mb-3">  
                  <label asp-for="Descripcion" class="control-label"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>
<div class="form-group mb-3">
                    <label asp-for="FechaLanzamiento" class="control-label"></label>
                <input asp-for="FechaLanzamiento" class="form-control" />
                <span asp-validation-for="FechaLanzamiento" class="text-danger"></span>
            </div>
<div class="form-group mb-3">
                    <label asp-for="Genero" class="control-label"></label>
                <select asp-for="Genero" class="form-control" asp-items="Html.GetEnumSelectList<Genero>()">
                    <option selected="selected" value="">Please select</option>>
                </select>
                <span asp-validation-for="Genero" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
    <label asp-for="ImagenUrl" class="control-label fw-bold">URL de la Imagen</label>
    <input asp-for="ImagenUrl" class="form-control" placeholder="Pegá el link de la foto aquí..." />
    <span asp-validation-for="ImagenUrl" class="text-danger"></span>
</div>
<div class="form-group mb-3">
                    <input type="submit" value="Crear" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Volver a la lista</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
